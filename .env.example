# agentns environment variables
# Copy to .env and fill in your values

# ── core ──────────────────────────────────────────────────────────────────────
AGENTNS_PORT=8200
AGENTNS_NAMESPACE=agents.local
AGENTNS_TLD=agentns.local
AGENTNS_HEALTH_INTERVAL=30

# ── persistence (optional) ────────────────────────────────────────────────────
# Leave MONGODB_URI blank to run fully in-memory (registrations lost on restart)
MONGODB_URI=
MONGODB_DB=agentns

# ── client shortcut ───────────────────────────────────────────────────────────
# Set this in your agent processes so AgentNSClient() needs no URL argument
AGENTNS_URL=http://localhost:8200
